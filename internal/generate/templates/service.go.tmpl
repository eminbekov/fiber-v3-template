	{{.EntityVariable}}, findByIDError := service.{{.EntityVariable}}Repository.FindByID(ctx, id)
	if findByIDError != nil {
		return nil, fmt.Errorf("{{.EntityName}}Service.FindByID: %w", findByIDError)
	}
	if service.cache != nil {
		_ = service.cache.Set(ctx, cacheKey, {{.EntityVariable}}, {{.EntityVariable}}CacheTTL)
	}
	return {{.EntityVariable}}, nil
}

func (service *{{.EntityName}}Service) List(ctx context.Context, page int, pageSize int) ([]domain.{{.EntityName}}, int64, error) {
