	if pageSize < 1 {
		pageSize = default{{.EntityName}}PageSize
	}
	if pageSize > max{{.EntityName}}PageSize {
		pageSize = max{{.EntityName}}PageSize
	}
	entities, totalCount, listError := service.{{.EntityVariable}}Repository.List(ctx, page, pageSize)
	if listError != nil {
		return nil, 0, fmt.Errorf("{{.EntityName}}Service.List: %w", listError)
	}
