func (service *{{.EntityName}}Service) FindByID(ctx context.Context, id uuid.UUID) (*domain.{{.EntityName}}, error) {
	if id == uuid.Nil {
		return nil, domain.ErrValidation
	}
	cacheKey := cache.{{.EntityName}}ByIDKey(id)
	var cachedEntity domain.{{.EntityName}}
	if service.cache != nil {
		if cacheError := service.cache.Get(ctx, cacheKey, &cachedEntity); cacheError == nil {
