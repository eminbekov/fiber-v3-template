package {{.APIVersion}}

import (
	"time"

	"{{.ModulePath}}/internal/domain"
)

type {{.EntityName}}Response struct {
	ID        string    `json:"id"`
	Name      string    `json:"name"`
	CreatedAt time.Time `json:"created_at"`
	UpdatedAt time.Time `json:"updated_at"`
}

type {{.EntityName}}ListResponse struct {
	Items    []{{.EntityName}}Response `json:"items"`
	Total    int64                   `json:"total"`
	Page     int                     `json:"page"`
	PageSize int                     `json:"page_size"`
}

func New{{.EntityName}}Response({{.EntityVariable}} domain.{{.EntityName}}) {{.EntityName}}Response {
	return {{.EntityName}}Response{
		ID:        {{.EntityVariable}}.ID.String(),
		Name:      {{.EntityVariable}}.Name,
		CreatedAt: {{.EntityVariable}}.CreatedAt,
		UpdatedAt: {{.EntityVariable}}.UpdatedAt,
	}
}

func New{{.EntityName}}ListResponse(entities []domain.{{.EntityName}}, total int64, page int, pageSize int) {{.EntityName}}ListResponse {
	items := make([]{{.EntityName}}Response, 0, len(entities))
	for _, itemValue := range entities {
		items = append(items, New{{.EntityName}}Response(itemValue))
	}
	return {{.EntityName}}ListResponse{
		Items:    items,
		Total:    total,
		Page:     page,
		PageSize: pageSize,
	}
}
