# Copy to .env and adjust. Never commit real secrets.

# development | production
ENVIRONMENT=development

# debug | info | warn | error
LOG_LEVEL=debug

# HTTP listen address (host:port or :port)
HTTP_LISTEN_ADDRESS=:8080

# Path to HTML templates directory.
VIEWS_PATH=./views

# Comma-separated allowed origins for CORS. Empty means deny cross-origin browser requests.
CORS_ALLOW_ORIGINS=

# Maximum request body size in bytes. Default is 4194304 (4 MB).
BODY_LIMIT=4194304

# OpenTelemetry collector endpoint (host:port). Empty disables telemetry export.
OTEL_EXPORTER_ENDPOINT=

# PostgreSQL connection string.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/fiber_template?sslmode=disable

# Redis connection string.
REDIS_URL=redis://localhost:6379/0

# NATS connection string.
NATS_URL=nats://localhost:4222

# gRPC listen address (host:port or :port).
GRPC_LISTEN_ADDRESS=:9090

# Session duration (Go duration format).
SESSION_DURATION=24h

# Storage: local | s3
STORAGE_TYPE=local

# Local filesystem root for uploads when STORAGE_TYPE=local.
STORAGE_LOCAL_BASE_PATH=./uploads

# S3-compatible API (AWS S3 or MinIO) when STORAGE_TYPE=s3.
# For AWS, leave S3_ENDPOINT empty. For MinIO use e.g. http://localhost:9000.
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=

# Optional public URL prefix for CDN or reverse-proxy (no trailing slash).
CDN_BASE_URL=

# Secret for HMAC-signed file URLs (development example only; use a strong random value in production).
FILE_SIGNING_KEY=change-me-in-production-use-long-random-secret

# Lifetime for signed download URLs (Go duration format, e.g. 15m, 1h).
SIGNED_URL_TTL=15m
